# Multi-Vac configuration.
# Copy to .env and fill in. If no API key is set, Multi-Vac runs OFFLINE with a
# deterministic stub model so the whole harness stays exercisable without a network.
#
# Multi-Vac is OpenAI-compatible: point it at ANY OpenAI-style endpoint
# (OpenAI, Cerebras, Together, Groq, Ollama, vLLM, OpenRouter, ...).

# --- Generic OpenAI-compatible (preferred) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Cerebras Gemma 4 (used by this hackathon) ---
# CEREBRAS_API_KEY=
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# MODEL_TEXT=gemma-4-31b

# --- Multi-Vac native names (override everything above if set) ---
# MULTIVAC_API_KEY=
# MULTIVAC_BASE_URL=
# MULTIVAC_MODEL=
# MULTIVAC_OFFLINE=0            # 1/true to force the offline stub model

# --- Harness knobs ---
# MULTIVAC_COMPACT_AFTER=40     # compact when history exceeds this many messages
# MULTIVAC_COMPACT_KEEP=8       # keep this many recent messages verbatim
# MULTIVAC_MAX_SUBAGENT_DEPTH=3 # sub-agent recursion guard
# MULTIVAC_TOOL_CALLS_LIMIT=20  # circuit breaker: max tool calls per turn
# MULTIVAC_REQUEST_LIMIT=25     # circuit breaker: max model requests per turn
